# ─────────────────────────────────────────────────────────────────────────────
# Azurebrains RRSS — variables de entorno
# Copia este fichero a .env y rellena los valores reales.
# El fichero .env NUNCA debe commitearse al repo.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure OpenAI (recurso existente oai-azurebrains-blog) ────────────────────
AZURE_OPENAI_ENDPOINT=https://oai-azurebrains-blog.openai.azure.com/
# API Key desde Key Vault kv-azrbrnsblog → secret azure-openai-api-key
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_COPY_MODEL=gpt-4.1
AZURE_OPENAI_IMAGE_MODEL=FLUX.2-pro

# ── Azure Blob Storage (hosting público de tarjetas visuales) ────────────────
AZURE_STORAGE_ACCOUNT_NAME=stazrbrnsmedia
AZURE_STORAGE_CONTAINER=rrss-media
# Connection string o usar Managed Identity en producción
AZURE_STORAGE_CONNECTION_STRING=

# ── Azure Cosmos DB (colección rrss en cosmos-azurebrains-chat-hlnywnla) ─────
COSMOS_ENDPOINT=https://cosmos-azurebrains-chat-hlnywnla.documents.azure.com:443/
# Clave de Cosmos DB o usar Managed Identity en producción
COSMOS_KEY=
COSMOS_DATABASE=chatdb
COSMOS_CONTAINER_RRSS=rrss

# ── Azure Key Vault (secretos de redes sociales) ─────────────────────────────
KEY_VAULT_URL=https://kv-azrbrnsblog.vault.azure.net/

# ── X (Twitter) API v2 ───────────────────────────────────────────────────────
# Obtener desde X Developer Portal (OAuth 2.0 user-context)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# ── LinkedIn API ─────────────────────────────────────────────────────────────
# Obtener desde LinkedIn Developers, permisos: w_member_social + w_organization_social
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_URN=urn:li:organization:<ID>

# ── Facebook / Meta API ──────────────────────────────────────────────────────
# Obtener desde Meta for Developers → App → Pages
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ── Instagram Graph API ──────────────────────────────────────────────────────
# Requiere cuenta profesional vinculada a la Facebook Page
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# ── Blog manifest (fuente de contenido) ──────────────────────────────────────
BLOG_MANIFEST_URL=https://blog.azurebrains.com/manifest.json

# ── Publisher API (cuando se despliega como servicio) ────────────────────────
# Usado por el workflow announce.yml del blog para llamar a este publisher
PUBLISHER_SECRET_TOKEN=
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
