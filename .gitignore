# ─────────────────────────────────────────────────────────────────────────────
# Azurebrains RRSS — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Variables de entorno (nunca al repo)
.env
.env.local
.env.*.local
!.env.example

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
dist/
build/
.eggs/

# Tests / cobertura
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# IDE
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo

# macOS / Linux
.DS_Store
*~
.fuse_hidden*

# Artefactos de ejecución
nohup.out
*.out
*.log

# Bicep / Terraform: no comitear estado
*.tfstate
*.tfstate.backup
.terraform/

# Pruebas locales
test-output/

# Claves de servicio / credenciales (nunca al repo)
blog-azurebrains-*.json
*-service-account*.json
*-key.json
